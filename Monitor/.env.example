# Copy to .env and replace placeholders. Never commit .env.
#
# PostgreSQL (API uses POSTGRES_HOST=127.0.0.1 via docker-compose override)
POSTGRES_USER=netmonitor
POSTGRES_PASSWORD=change_me_strong_db_password
POSTGRES_DB=netmonitor

# pgAdmin web login (and optional master password on first launch)
PGADMIN_DEFAULT_EMAIL=admin@example.local
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_login_password

# AdGuard Home (API polling)
ADGUARD_URL=http://192.168.0.150:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=change_me_adguard_api_or_ui_password

# Scanner / polling
POLL_INTERVAL_SEC=120
ADGUARD_QUERY_POLL_SEC=300
NETWORK_CIDR=192.168.0.0/24
# SCAN_IFACE=bond0
