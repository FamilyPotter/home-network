# =============================================================================
# FamilyPotter Network Stack — .gitignore
# =============================================================================

# Secrets — never commit these
.env
DDNS/ddclient.conf
DHCP/ddclient/ddclient.conf

# Tailscale state directory contains WireGuard private keys
VPN/tailscale/

# AdGuard: optional local snapshot of live NAS config (may duplicate password hash)
AdGuard/conf/AdGuardHome_nas_current.yaml

# Monitor: private device inventory (committed template is seed_inventory.example.sql)
Monitor/db/seed_inventory.sql


# WireGuard private keys (if ever generated)
VPN/wireguard/*.conf
VPN/wireguard/privatekey
VPN/wireguard/publickey
!VPN/wireguard/README-wireguard.md

# QNAP / Windows artefacts
.vs/
*.slnx
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Cursor IDE
.cursor/

# macOS
.DS_Store
